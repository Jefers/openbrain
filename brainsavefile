#!/bin/bash
# Save clipboard content to a text file for add_file.py

TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
OUTPUT_FILE="$HOME/LocalFile/openbrain/llm_thoughts_${TIMESTAMP}.txt"

pbpaste > "$OUTPUT_FILE"

echo "✅ Saved clipboard to $OUTPUT_FILE"
echo "📝 File preview:"
echo "=================="
head -10 "$OUTPUT_FILE"
echo "=================="
echo ""
echo "Lines: $(wc -l < "$OUTPUT_FILE" | tr -d ' ')"
echo ""
echo "To load into Open Brain:"
echo "  addtxt $OUTPUT_FILE"
