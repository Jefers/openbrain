#!/bin/bash
# Load the LLM prompt into clipboard

PROMPT_FILE="$HOME/LocalFile/openbrain/llm_prompt.txt"

if [ ! -f "$PROMPT_FILE" ]; then
    echo "❌ Prompt file not found at $PROMPT_FILE"
    exit 1
fi

# Copy to clipboard (macOS)
cat "$PROMPT_FILE" | pbcopy

echo "✅ LLM prompt copied to clipboard!"
echo "📋 Paste it into your conversation with another AI"
echo ""
echo "After you get the response, run:"
echo "  pbpaste > ~/LocalFile/openbrain/llm_output.txt"
echo "  Then manually paste into add_llm.py"
