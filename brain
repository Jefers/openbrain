#!/bin/bash
# Open Brain CLI Tool
# Usage: brain [command] [args]

OPENBRAIN_DIR="/Users/jeffgordon/LocalFile/openbrain"
DB_NAME="openbrain"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to show help
show_help() {
    echo -e "${GREEN}🧠 Open Brain CLI${NC}"
    echo "================"
    echo ""
    echo "Commands:"
    echo "  brain recent [days] [limit]   - Show recent memories"
    echo "  brain search <keyword> [limit] - Search memories"
    echo "  brain stats                   - Show database statistics"
    echo "  brain add \"thought\"           - Add a memory directly"
    echo "  brain list                    - List all memories (ID + preview)"
    echo "  brain count                   - Count total memories"
    echo "  brain help                    - Show this help"
    echo ""
    echo "Examples:"
    echo "  brain recent                  # Last 7 days, 10 memories"
    echo "  brain recent 30 20            # Last 30 days, 20 memories"
    echo "  brain search \"project\"        # Search for 'project'"
    echo "  brain add \"New idea: build a robot\""
    echo ""
}

# Function to show recent memories
show_recent() {
    local days=${1:-7}
    local limit=${2:-10}
    
    echo -e "\n${GREEN}📝 Recent Memories (last ${days} days)${NC}"
    echo "========================================"
    
    # Query with formatted output
    psql -d "$DB_NAME" -c "
        SELECT 
            '[' || TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI') || '] ' ||
            LEFT(content, 100) || 
            CASE WHEN LENGTH(content) > 100 THEN '...' ELSE '' END
        FROM memories 
        WHERE created_at > NOW() - INTERVAL '${days} days'
        ORDER BY created_at DESC 
        LIMIT ${limit};
    " -t
    
    # Show count
    local count=$(psql -d "$DB_NAME" -c "
        SELECT COUNT(*) 
        FROM memories 
        WHERE created_at > NOW() - INTERVAL '${days} days';
    " -t | tr -d ' ' | tr -d '\n')
    
    echo -e "\n${YELLOW}📊 Found ${count} memories from last ${days} days${NC}"
}

# Function to search memories
search_memories() {
    local keyword="$1"
    local limit=${2:-10}
    
    if [ -z "$keyword" ]; then
        echo -e "${RED}Error: Please provide a search keyword${NC}"
        echo "Usage: brain search <keyword> [limit]"
        exit 1
    fi
    
    echo -e "\n${GREEN}🔍 Searching for \"${keyword}\"${NC}"
    echo "========================================"
    
    # Query with case-insensitive search
    psql -d "$DB_NAME" -c "
        SELECT 
            '[' || TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI') || '] ' ||
            content
        FROM memories 
        WHERE content ILIKE '%${keyword}%'
        ORDER BY created_at DESC 
        LIMIT ${limit};
    " -t
    
    # Show count
    local count=$(psql -d "$DB_NAME" -c "
        SELECT COUNT(*) 
        FROM memories 
        WHERE content ILIKE '%${keyword}%';
    " -t | tr -d ' ' | tr -d '\n')
    
    echo -e "\n${YELLOW}📊 Found ${count} matches for \"${keyword}\"${NC}"
}

# Function to show statistics
show_stats() {
    echo -e "\n${GREEN}📊 Open Brain Statistics${NC}"
    echo "========================================"
    
    # Total memories
    local total=$(psql -d "$DB_NAME" -c "SELECT COUNT(*) FROM memories;" -t | tr -d ' ' | tr -d '\n')
    echo -e "Total memories:      ${total}"
    
    # Last week
    local last_week=$(psql -d "$DB_NAME" -c "
        SELECT COUNT(*) 
        FROM memories 
        WHERE created_at > NOW() - INTERVAL '7 days';
    " -t | tr -d ' ' | tr -d '\n')
    echo -e "Last 7 days:         ${last_week}"
    
    # Last month
    local last_month=$(psql -d "$DB_NAME" -c "
        SELECT COUNT(*) 
        FROM memories 
        WHERE created_at > NOW() - INTERVAL '30 days';
    " -t | tr -d ' ' | tr -d '\n')
    echo -e "Last 30 days:        ${last_month}"
    
    # Latest memory
    local latest=$(psql -d "$DB_NAME" -c "
        SELECT TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI')
        FROM memories 
        ORDER BY created_at DESC 
        LIMIT 1;
    " -t | tr -d '\n')
    
    if [ -n "$latest" ] && [ "$latest" != "(0 rows)" ]; then
        echo -e "Latest memory:       ${latest}"
    else
        echo -e "Latest memory:       Never"
    fi
    
    # Memory with embeddings
    local with_embeddings=$(psql -d "$DB_NAME" -c "
        SELECT COUNT(*) 
        FROM memories 
        WHERE embedding IS NOT NULL;
    " -t | tr -d ' ' | tr -d '\n')
    
    if [ "$total" -gt 0 ]; then
        local percent=$((with_embeddings * 100 / total))
        echo -e "With embeddings:     ${with_embeddings} (${percent}%)"
    fi
}

# Function to add a memory
add_memory() {
    local content="$1"
    
    if [ -z "$content" ]; then
        echo -e "${RED}Error: Please provide content for the memory${NC}"
        echo "Usage: brain add \"Your thought here\""
        exit 1
    fi
    
    echo -e "\n${GREEN}➕ Adding memory...${NC}"
    
    # Insert into database
    local result=$(psql -d "$DB_NAME" -c "
        INSERT INTO memories (content) 
        VALUES ('$(echo "$content" | sed "s/'/''/g")') 
        RETURNING id, created_at;
    " -t)
    
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✅ Memory added successfully!${NC}"
        echo "$result" | while read line; do
            if [[ -n "$line" ]]; then
                echo "  ID: $(echo "$line" | cut -d'|' -f1 | tr -d ' ')"
                echo "  Time: $(echo "$line" | cut -d'|' -f2 | tr -d ' ')"
            fi
        done
    else
        echo -e "${RED}❌ Failed to add memory${NC}"
    fi
}

# Function to list all memories
list_memories() {
    local limit=${1:-20}
    
    echo -e "\n${GREEN}📋 All Memories (newest first)${NC}"
    echo "========================================"
    
    psql -d "$DB_NAME" -c "
        SELECT 
            'ID: ' || id || ' | ' ||
            '[' || TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI') || '] ' ||
            LEFT(content, 80) || 
            CASE WHEN LENGTH(content) > 80 THEN '...' ELSE '' END
        FROM memories 
        ORDER BY created_at DESC 
        LIMIT ${limit};
    " -t
    
    local total=$(psql -d "$DB_NAME" -c "SELECT COUNT(*) FROM memories;" -t | tr -d ' ' | tr -d '\n')
    echo -e "\n${YELLOW}📊 Total memories in database: ${total}${NC}"
}

# Function to count memories
count_memories() {
    local total=$(psql -d "$DB_NAME" -c "SELECT COUNT(*) FROM memories;" -t | tr -d ' ' | tr -d '\n')
    echo -e "${GREEN}🧠 Total memories: ${total}${NC}"
    
    # Breakdown by time
    echo -e "\n${BLUE}Breakdown by time:${NC}"
    psql -d "$DB_NAME" -c "
        SELECT 
            CASE 
                WHEN created_at > NOW() - INTERVAL '1 day' THEN 'Last 24 hours'
                WHEN created_at > NOW() - INTERVAL '7 days' THEN 'Last 7 days'
                WHEN created_at > NOW() - INTERVAL '30 days' THEN 'Last 30 days'
                ELSE 'Older'
            END as period,
            COUNT(*) as count
        FROM memories 
        GROUP BY 1 
        ORDER BY 
            CASE period
                WHEN 'Last 24 hours' THEN 1
                WHEN 'Last 7 days' THEN 2
                WHEN 'Last 30 days' THEN 3
                ELSE 4
            END;
    " -t
}

# Main command parsing
case "$1" in
    "recent")
        show_recent "$2" "$3"
        ;;
    "search")
        search_memories "$2" "$3"
        ;;
    "stats")
        show_stats
        ;;
    "add")
        # Handle multi-word input
        if [ -z "$2" ]; then
            echo -e "${RED}Error: Please provide content for the memory${NC}"
            echo "Usage: brain add \"Your thought here\""
            exit 1
        fi
        # Join all arguments after "add" as the content
        shift
        content="$*"
        add_memory "$content"
        ;;
    "list")
        list_memories "$2"
        ;;
    "count")
        count_memories
        ;;
    "help"|"--help"|"-h"|"")
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        show_help
        exit 1
        ;;
esac