#!/bin/bash
# Open Brain CLI Tool
# Usage: brain [command] [args]

OPENBRAIN_DIR="/Users/jeffgordon/LocalFile/openbrain"
DB_NAME="openbrain"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to show help
show_help() {
    echo -e "${GREEN}🧠 Open Brain CLI${NC}"
    echo "================"
    echo ""
    echo "Commands:"
    echo "  brain recent [days] [limit]    - Show recent memories"
    echo "  brain search <keyword> [limit]  - Keyword search"
    echo "  brain semantic <query> [limit]  - SEMANTIC search by meaning"
    echo "  brain stats                     - Show database statistics"
    echo "  brain add \"thought\"            - Add a memory directly"
    echo "  brain list [limit]               - List all memories"
    echo "  brain count                      - Count total memories"
    echo "  brain categories                  - Show category breakdown"
    echo "  brain help                       - Show this help"
    echo ""
    echo "Examples:"
    echo "  brain recent                     # Last 7 days, 10 memories"
    echo "  brain recent 30 20               # Last 30 days, 20 memories"
    echo "  brain search \"project\"           # Keyword search"
    echo "  brain semantic \"why am I building this\"  # Semantic search"
    echo "  brain add \"New idea: build a robot\""
    echo "  brain categories                  # Show memory categories"
    echo ""
}

# Function to show recent memories
show_recent() {
    local days=${1:-7}
    local limit=${2:-10}
    
    echo -e "\n${GREEN}📝 Recent Memories (last ${days} days)${NC}"
    echo "========================================"
    
    psql -d "$DB_NAME" -c "
        SELECT 
            '[' || TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI') || '] [' || 
            COALESCE(metadata->>'category', 'uncategorized') || '] ' ||
            LEFT(content, 100) || 
            CASE WHEN LENGTH(content) > 100 THEN '...' ELSE '' END
        FROM memories 
        WHERE created_at > NOW() - INTERVAL '${days} days'
        ORDER BY created_at DESC 
        LIMIT ${limit};
    " -t
    
    local count=$(psql -d "$DB_NAME" -c "
        SELECT COUNT(*) 
        FROM memories 
        WHERE created_at > NOW() - INTERVAL '${days} days';
    " -t | tr -d ' ' | tr -d '\n')
    
    echo -e "\n${YELLOW}📊 Found ${count} memories from last ${days} days${NC}"
}

# Function to keyword search memories
search_memories() {
    local keyword="$1"
    local limit=${2:-10}
    
    if [ -z "$keyword" ]; then
        echo -e "${RED}Error: Please provide a search keyword${NC}"
        echo "Usage: brain search <keyword> [limit]"
        exit 1
    fi
    
    echo -e "\n${GREEN}🔍 Keyword Search: \"${keyword}\"${NC}"
    echo "========================================"
    
    psql -d "$DB_NAME" -c "
        SELECT 
            '[' || TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI') || '] [' || 
            COALESCE(metadata->>'category', 'uncategorized') || '] ' ||
            LEFT(content, 150) || 
            CASE WHEN LENGTH(content) > 150 THEN '...' ELSE '' END
        FROM memories 
        WHERE content ILIKE '%${keyword}%'
        ORDER BY created_at DESC 
        LIMIT ${limit};
    " -t
    
    local count=$(psql -d "$DB_NAME" -c "
        SELECT COUNT(*) 
        FROM memories 
        WHERE content ILIKE '%${keyword}%';
    " -t | tr -d ' ' | tr -d '\n')
    
    echo -e "\n${YELLOW}📊 Found ${count} matches for \"${keyword}\"${NC}"
}

# NEW: Function for semantic search
semantic_search() {
    local query="$1"
    local limit=${2:-8}
    
    if [ -z "$query" ]; then
        echo -e "${RED}Error: Please provide a search query${NC}"
        echo "Usage: brain semantic <query> [limit]"
        exit 1
    fi
    
    echo -e "\n${GREEN}🧠 Semantic Search: \"${query}\"${NC}"
    echo "========================================"
    
    # Use Python script to perform semantic search
    cd "$OPENBRAIN_DIR"
    source venv/bin/activate 2>/dev/null
    
    python3 -c "
import sys
import psycopg2
from sentence_transformers import SentenceTransformer
import os
import warnings
warnings.filterwarnings('ignore')

# Suppress transformer logs
os.environ['TF_CPP_MIN_LOG_LEVEL'] = '3'

try:
    # Connect to database
    conn = psycopg2.connect(dbname='openbrain', user='jeffgordon', host='localhost')
    cur = conn.cursor()
    
    # Load model
    model = SentenceTransformer('all-MiniLM-L6-v2')
    
    # Encode query
    query = '$query'
    emb = model.encode(query).tolist()
    
    # Search database
    cur.execute(\"\"\"
        SELECT content, 
               TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI') as date,
               COALESCE(metadata->>'category', 'uncategorized') as category,
               1 - (embedding <=> %s::vector) as similarity
        FROM memories 
        WHERE embedding IS NOT NULL
        ORDER BY similarity DESC 
        LIMIT %s
    \"\"\", (emb, $limit))
    
    results = cur.fetchall()
    
    if results:
        for content, date, category, similarity in results:
            # Truncate long content
            if len(content) > 150:
                content = content[:147] + '...'
            print(f\"[{date}] ({similarity:.2f}) [{category}]\\n{content}\\n\")
    else:
        print(\"No matches found\")
        
    conn.close()
    
except Exception as e:
    print(f\"Error: {e}\")
    sys.exit(1)
"
    
    echo -e "\n${YELLOW}📊 Top ${limit} semantic matches for \"${query}\"${NC}"
}

# Function to show statistics
show_stats() {
    echo -e "\n${GREEN}📊 Open Brain Statistics${NC}"
    echo "========================================"
    
    local total=$(psql -d "$DB_NAME" -c "SELECT COUNT(*) FROM memories;" -t | tr -d ' ' | tr -d '\n')
    echo -e "Total memories:      ${total}"
    
    local last_week=$(psql -d "$DB_NAME" -c "
        SELECT COUNT(*) 
        FROM memories 
        WHERE created_at > NOW() - INTERVAL '7 days';
    " -t | tr -d ' ' | tr -d '\n')
    echo -e "Last 7 days:         ${last_week}"
    
    local last_month=$(psql -d "$DB_NAME" -c "
        SELECT COUNT(*) 
        FROM memories 
        WHERE created_at > NOW() - INTERVAL '30 days';
    " -t | tr -d ' ' | tr -d '\n')
    echo -e "Last 30 days:        ${last_month}"
    
    local latest=$(psql -d "$DB_NAME" -c "
        SELECT TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI')
        FROM memories 
        ORDER BY created_at DESC 
        LIMIT 1;
    " -t | tr -d '\n')
    
    if [ -n "$latest" ] && [ "$latest" != "(0 rows)" ]; then
        echo -e "Latest memory:       ${latest}"
    else
        echo -e "Latest memory:       Never"
    fi
    
    local with_embeddings=$(psql -d "$DB_NAME" -c "
        SELECT COUNT(*) 
        FROM memories 
        WHERE embedding IS NOT NULL;
    " -t | tr -d ' ' | tr -d '\n')
    
    if [ "$total" -gt 0 ]; then
        local percent=$((with_embeddings * 100 / total))
        echo -e "With embeddings:     ${with_embeddings} (${percent}%)"
    fi
    
    # Show category breakdown
    echo -e "\n${BLUE}Category Breakdown:${NC}"
    psql -d "$DB_NAME" -c "
        SELECT 
            COALESCE(metadata->>'category', 'uncategorized') as category,
            COUNT(*) as count
        FROM memories 
        GROUP BY 1 
        ORDER BY 2 DESC 
        LIMIT 10;
    " -t
}

# Function to add a memory
add_memory() {
    local content="$1"
    
    if [ -z "$content" ]; then
        echo -e "${RED}Error: Please provide content for the memory${NC}"
        echo "Usage: brain add \"Your thought here\""
        exit 1
    fi
    
    echo -e "\n${GREEN}➕ Adding memory...${NC}"
    
    # Insert into database
    local result=$(psql -d "$DB_NAME" -c "
        INSERT INTO memories (content) 
        VALUES ('$(echo "$content" | sed "s/'/''/g")') 
        RETURNING id, created_at;
    " -t)
    
    if [ $? -eq 0 ]; then
        echo -e "${GREEN}✅ Memory added successfully!${NC}"
        echo "$result" | while read line; do
            if [[ -n "$line" ]]; then
                echo "  ID: $(echo "$line" | cut -d'|' -f1 | tr -d ' ')"
                echo "  Time: $(echo "$line" | cut -d'|' -f2 | tr -d ' ')"
            fi
        done
        echo -e "${YELLOW}⚠️  Note: Run 'brain generate-embeddings' to enable semantic search on this memory${NC}"
    else
        echo -e "${RED}❌ Failed to add memory${NC}"
    fi
}

# Function to list all memories
list_memories() {
    local limit=${1:-20}
    
    echo -e "\n${GREEN}📋 All Memories (newest first)${NC}"
    echo "========================================"
    
    psql -d "$DB_NAME" -c "
        SELECT 
            'ID: ' || id || ' | [' ||
            TO_CHAR(created_at, 'YYYY-MM-DD HH24:MI') || '] [' || 
            COALESCE(metadata->>'category', 'uncategorized') || '] ' ||
            LEFT(content, 80) || 
            CASE WHEN LENGTH(content) > 80 THEN '...' ELSE '' END
        FROM memories 
        ORDER BY created_at DESC 
        LIMIT ${limit};
    " -t
    
    local total=$(psql -d "$DB_NAME" -c "SELECT COUNT(*) FROM memories;" -t | tr -d ' ' | tr -d '\n')
    echo -e "\n${YELLOW}📊 Total memories in database: ${total}${NC}"
}

# Function to count memories
count_memories() {
    local total=$(psql -d "$DB_NAME" -c "SELECT COUNT(*) FROM memories;" -t | tr -d ' ' | tr -d '\n')
    echo -e "${GREEN}🧠 Total memories: ${total}${NC}"
    
    echo -e "\n${BLUE}Breakdown by time:${NC}"
    psql -d "$DB_NAME" -c "
        SELECT 
            CASE 
                WHEN created_at > NOW() - INTERVAL '1 day' THEN 'Last 24 hours'
                WHEN created_at > NOW() - INTERVAL '7 days' THEN 'Last 7 days'
                WHEN created_at > NOW() - INTERVAL '30 days' THEN 'Last 30 days'
                ELSE 'Older'
            END as period,
            COUNT(*) as count
        FROM memories 
        GROUP BY 1 
        ORDER BY 
            CASE period
                WHEN 'Last 24 hours' THEN 1
                WHEN 'Last 7 days' THEN 2
                WHEN 'Last 30 days' THEN 3
                ELSE 4
            END;
    " -t
}

# Function to show categories
show_categories() {
    echo -e "\n${GREEN}📊 Category Breakdown${NC}"
    echo "========================================"
    
    psql -d "$DB_NAME" -c "
        SELECT 
            COALESCE(metadata->>'category', 'uncategorized') as category,
            COUNT(*) as count,
            ROUND(100.0 * COUNT(*) / SUM(COUNT(*)) OVER(), 1) as percentage
        FROM memories 
        GROUP BY 1 
        ORDER BY 2 DESC;
    "
}

# Function to generate embeddings for unembedded memories
generate_embeddings() {
    echo -e "\n${GREEN}🔄 Generating embeddings for memories without them...${NC}"
    
    cd "$OPENBRAIN_DIR"
    source venv/bin/activate 2>/dev/null
    
    python3 -c "
import psycopg2
from sentence_transformers import SentenceTransformer
import os

conn = psycopg2.connect(dbname='openbrain', user='jeffgordon', host='localhost')
cur = conn.cursor()

# Find memories without embeddings
cur.execute(\"SELECT id, content FROM memories WHERE embedding IS NULL\")
missing = cur.fetchall()

if not missing:
    print('✅ No missing embeddings found!')
    conn.close()
    exit(0)

print(f'📝 Found {len(missing)} memories without embeddings')
print('🔄 Loading model...')
model = SentenceTransformer('all-MiniLM-L6-v2')

for mem_id, content in missing:
    print(f'  Generating embedding for ID {mem_id}')
    embedding = model.encode(content).tolist()
    cur.execute(
        \"UPDATE memories SET embedding = %s::vector WHERE id = %s\",
        (embedding, mem_id)
    )

conn.commit()
cur.close()
conn.close()
print(f'✅ Generated embeddings for {len(missing)} memories!')
"
}

# Main command parsing
case "$1" in
    "recent")
        show_recent "$2" "$3"
        ;;
    "search")
        search_memories "$2" "$3"
        ;;
    "semantic")
        semantic_search "$2" "$3"
        ;;
    "stats")
        show_stats
        ;;
    "add")
        if [ -z "$2" ]; then
            echo -e "${RED}Error: Please provide content for the memory${NC}"
            echo "Usage: brain add \"Your thought here\""
            exit 1
        fi
        shift
        content="$*"
        add_memory "$content"
        ;;
    "list")
        list_memories "$2"
        ;;
    "count")
        count_memories
        ;;
    "categories")
        show_categories
        ;;
    "generate-embeddings")
        generate_embeddings
        ;;
    "help"|"--help"|"-h"|"")
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        show_help
        exit 1
        ;;
esac