#!/bin/bash
# Load the file format prompt into clipboard

PROMPT_FILE="$HOME/LocalFile/openbrain/file_prompt.txt"

if [ ! -f "$PROMPT_FILE" ]; then
    echo "❌ Prompt file not found at $PROMPT_FILE"
    exit 1
fi

cat "$PROMPT_FILE" | pbcopy

echo "✅ File format prompt copied to clipboard!"
echo "📋 Paste it into your conversation with another AI"
echo ""
echo "After you get the response, run:"
echo "  brainsavefile"
